# Discord Bot Configuration
# Get your bot token from: https://discord.com/developers/applications
DISCORD_BOT_TOKEN=your_bot_token_here

# LLM API Configuration
# OpenAI-compatible API (OpenAI, Anthropic, Ollama, LM Studio, etc.)
LLM_API_KEY=
LLM_BASE_URL=https://api.openai.com/v1  # For OpenAI
# LLM_BASE_URL=http://localhost:1234/v1  # For LM Studio/Ollama local
LLM_MODEL=gpt-4o-mini

# FFLogs V1 API (public character parse lookups)
# Get key from https://www.fflogs.com/profile
FFLOGS_API_KEY=

# Bot Behavior
BOT_PREFIX=!  # For text commands (leave empty to disable)
BOT_NAME=AI Assistant

# Rate Limiting
MAX_MESSAGES_PER_MINUTE=10  # Per user
MAX_TOKENS_PER_DAY=100000   # Total tokens per day (rough cost control)

# Memory Settings
MAX_CONVERSATION_HISTORY=10  # Number of messages to remember per channel
MEMORY_CLEANUP_HOURS=24      # How often to clean old conversations
